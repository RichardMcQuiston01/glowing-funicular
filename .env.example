# =============================================================================
# Etsy Jig Scripts — Shared Configuration
# Place this file in the same directory as the Python scripts.
# Lines starting with # are comments and are ignored.
# =============================================================================

# ---------------------------------------------------------------------------
# sync_folders.py
# ---------------------------------------------------------------------------

# Source folder — subfolder names are read from here
SYNC_SRC_DIR=D:\3DFiles\F2_Jigs

# Destination folder — missing subfolders are created here
SYNC_DEST_DIR=D:\LaserFiles\F2_Jigs


# ---------------------------------------------------------------------------
# sync_digital_addin_files.py
# ---------------------------------------------------------------------------

# Folder containing the thank-you PDF(s) to distribute
ADDIN_SOURCE_DIR=D:\AddToDigitalDownloads

# 3D-printing jigs root (also used by create_etsy_zips.py)
JIGS_3DPRINT_DIR=D:\3DFiles\F2_Jigs

# Laser jigs root
JIGS_LASER_DIR=D:\LaserFiles\F2_Jigs


# ---------------------------------------------------------------------------
# create_etsy_zips.py
# ---------------------------------------------------------------------------

# Where finished ZIPs are written (defaults to JIGS_3DPRINT_DIR if blank)
ZIP_OUTPUT_DIR=D:\Completed\F2_Jigs

# Where pre-run backup ZIPs are stored (defaults to JIGS_3DPRINT_DIR\_Backups if blank)
ZIP_BACKUP_DIR=D:\3DFiles\F2_Jigs\_Backups

# Where log files are written (defaults to JIGS_3DPRINT_DIR if blank)
ZIP_LOG_DIR=D:\LogFiles\F2_Jigs

# Prefix applied to every output ZIP filename
ZIP_PREFIX=McQForYouDesign_
